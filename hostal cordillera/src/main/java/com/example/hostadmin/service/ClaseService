package com.example.hostadmin.Service;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import com.example.hostadmin.Repository.ReservaRepository;
import com.example.hostadmin.model.Reserva;

@Service
public class ReservaService {
    @Autowired
    private ReservaRepository reservaRepository;
}

public list<Reserva> obtenerTodos() {
    return reservaRepository .findAll();
}

public Reserva buscarPorId(Integer id) {
        return reservaRepository.findById(id)
                .orElseThrow(() -> new RuntimeException("la reserva no existe"));
}

public String eliminar(Integer id) {
    try {
        Reserva reserva = reservaRepository.findById(id)
            .orElseThrow(() -> new RuntimeException("la reserva: " + id + " no existe"));
            reservaRepository.delete(reserva);
            return "El héroe '" + reserva.getNombre() + "' se elimino la reserva.";
        } catch (RuntimeException e) {
            return e.getMessage();
        }
}

public Reserva guardarReserva(Reserva reserva) {
        return reservaRepository.save(reserva);
}
